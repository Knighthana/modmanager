    "name": "root",
    "type": "folder",
    "children": [
      {
        "name": "media",
        "type": "folder",
        "children": [
          {
            "name": "packages",
            "type": "folder",
            "children": [
              {
                "name": "GFL_Castling",
                "type": "folder",
                "children": [
                  {
                    "name": "orange_cat.ico",
                    "type": "file",
                    "isbackuped": true,
                    "hashtype": "sha256",
                    "hashvalue": "a9bbb0755f80a61a9296ed3e9be7934286b536abb9f2e8e3e4b57c9fb35d9ee4"
                  }
                ]
              },
              {
                "name": "optional",
