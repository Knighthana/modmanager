{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://knighthana.github.io/modmanager/schemas/user_config.schema.json",
    "title": "UserConfig",
    "description": "用户配置文件 schema。控制工具运行时行为（备份前缀、输出路径、路径别名）。",
    "type": "object",
    "required": [],
    "additionalProperties": true,
    "properties": {
        "schema_namespace": {
            "description": "Schema namespace identifier.",
            "type": "string",
            "const": "KMM_UserConfig"
        },
        "schema_version": {
            "description": "Schema version string.",
            "type": "string"
        },
        "bakprefix": {
            "description": "备份目录名前缀。默认值 'kmmbackup_'。",
            "type": "string",
            "default": "kmmbackup_"
        },
        "bakignore": {
            "description": "备份扫描时忽略的路径/通配模式列表。",
            "type": "array",
            "default": ["kmmbackup_"],
            "items": {
                "type": "string"
            }
        },
        "aggregated_ruleset_output_path": {
            "description": "aggregated_rule_set.json 的输出路径。为 null 时使用平台默认位置。",
            "type": ["string", "null"],
            "default": null
        },
        "rule_sources": {
            "description": "规则文件来源列表。目录以 / 结尾（自动扫描 *.kmmrule.json），或以 .kmmrule.json 结尾的文件直接加载。后端保存时自动归一化：检测目录路径缺 / 则补齐。",
            "type": "array",
            "default": [],
            "items": {
                "type": "string"
            }
        },
        "path_alias": {
            "description": "路径别名列表。当前无消费者，保留供未来扩展。",
            "type": "array",
            "default": [],
            "items": {
                "type": "object",
                "required": ["description", "path_handle", "path_target"],
                "additionalProperties": false,
                "properties": {
                    "description": {
                        "description": "人类可读的别名说明。",
                        "type": "string"
                    },
                    "path_handle": {
                        "description": "路径别名引用句柄。",
                        "type": "string"
                    },
                    "path_target": {
                        "description": "别名对应的本地文件系统路径。",
                        "type": "string"
                    }
                }
            }
        },
        "databases": {
            "description": "database 名称→路径映射。对象天然防重，每个 entry 是对象为未来扩展留空间。key 为 database 名称，value 包含 path 属性。",
            "type": "object",
            "default": {},
            "additionalProperties": {
                "type": "object",
                "required": ["path"],
                "additionalProperties": false,
                "properties": {
                    "path": {
                        "description": "database 文件的本地路径。",
                        "type": "string"
                    }
                }
            }
        }
    }
}
