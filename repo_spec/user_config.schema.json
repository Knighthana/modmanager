{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://knighthana.github.io/modmanager/schemas/user_config.schema.json",
    "title": "UserConfig",
    "description": "用户配置文件 schema。控制工具运行时行为（备份前缀、忽略规则、路径别名、工作区、数据库、规则来源）。",
    "type": "object",
    "required": [
        "schema_namespace",
        "schema_version",
        "baksuffix",
        "rule_sources",
        "workspace_dir",
        "databases"
    ],
    "additionalProperties": false,
    "properties": {
        "schema_namespace": {
            "description": "Schema namespace identifier.",
            "type": "string",
            "const": "KMM_UserConfig"
        },
        "schema_version": {
            "description": "数据格式必须遵守的schema版本号。",
            "type": "string",
            "const": "knighthana@0.1.0"
        },
        "baksuffix": {
            "description": "备份目录名后缀。目录格式为 {id}.{hex}.{baksuffix}/。",
            "type": "string"
        },
        "bakignore": {
            "description": "备份时忽略的目录名后缀（系统自动维护，与 baksuffix 联动）。仅 backup 操作生效。",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "rule_sources": {
            "description": "规则文件来源映射——{name: {paths: [...]}}。与 databases 格式一致。前端只传 name，后端按名解析路径列表。",
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "required": ["paths"],
                "additionalProperties": false,
                "properties": {
                    "paths": {
                        "description": "规则文件路径列表。目录以 / 结尾（自动扫描 *.kmmrule.json），文件以 .kmmrule.json 结尾（直接加载）。",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "path_alias": {
            "description": "路径别名列表。当前无消费者，保留供未来扩展。",
            "type": "array",
            "items": {
                "type": "object",
                "required": ["description", "path_handle", "path_target"],
                "additionalProperties": false,
                "properties": {
                    "description": {
                        "description": "人类可读的别名说明。",
                        "type": "string"
                    },
                    "path_handle": {
                        "description": "路径别名引用句柄。",
                        "type": "string"
                    },
                    "path_target": {
                        "description": "别名对应的本地文件系统路径。",
                        "type": "string"
                    }
                }
            }
        },
        "workspace_dir": {
            "description": "工作区根目录。bootstrap 首次创建时按平台填入默认值并固化。之后运行时以 user_config.workspace_dir 为准，不做平台回退。",
            "type": ["string", "null"]
        },
        "databases": {
            "description": "database 名称→路径映射。key 为 database 名称，value 包含 path 属性。",
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "required": ["path"],
                "additionalProperties": false,
                "properties": {
                    "path": {
                        "description": "database 文件的本地路径。",
                        "type": "string"
                    }
                }
            }
        }
    }
}
