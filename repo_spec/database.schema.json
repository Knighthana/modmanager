{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://knighthana.github.io/modmanager/schemas/database.schema.json",
    "title": "Database",
    "description": "Steam 库发现结果与 mod 清单。由 Steam 扫描器生成，经数据源页面去重后进入流水线。",
    "type": "object",
    "required": ["steamlib", "game", "mod"],
    "additionalProperties": false,
    "properties": {
        "OS": {
            "$ref": "#/$defs/OS"
        },
        "steamlib": {
            "description": "发现的 Steam 库列表。",
            "type": "array",
            "items": {
                "$ref": "#/$defs/SteamLib"
            }
        },
        "game": {
            "description": "各 Steam 库中发现的已安装游戏列表。同名 appid 可在不同库中出现多次；同一 appid 最多一个条目的 managed 为 true。",
            "type": "array",
            "items": {
                "$ref": "#/$defs/Game"
            }
        },
        "mod": {
            "description": "发现的 workshop mod 与本地 mod 列表。同 mixed_id 可在不同路径出现多次；同一 mixed_id 最多一个条目的 managed 为 true。",
            "type": "array",
            "items": {
                "$ref": "#/$defs/Mod"
            }
        },
        "warnings": {
            "description": "扫描过程中产生的警告信息。",
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "history": {
            "description": "操作历史记录（预留，当前为空数组）。",
            "type": "array",
            "default": []
        }
    },
    "$defs": {
        "OS": {
            "description": "操作系统与路径风格信息。",
            "type": "object",
            "required": ["workingpathstyle", "steamlibpathstyle"],
            "additionalProperties": false,
            "properties": {
                "workingpathstyle": {
                    "description": "当前运行环境的路径风格。",
                    "type": "string",
                    "enum": ["linux", "windows"]
                },
                "steamlibpathstyle": {
                    "description": "Steam 库的原始路径风格。",
                    "type": "string",
                    "enum": ["linux", "windows"]
                }
            }
        },
        "SteamLib": {
            "description": "单个 Steam 库的信息。",
            "type": "object",
            "required": ["path", "contains_libraryfolders_vdf"],
            "additionalProperties": false,
            "properties": {
                "path": {
                    "description": "Steam 库的根路径（目录，必须以 / 结尾）。",
                    "type": "string",
                    "pattern": "/$"
                },
                "contains_libraryfolders_vdf": {
                    "description": "此路径下是否存在 libraryfolders.vdf。",
                    "type": "boolean"
                }
            }
        },
        "Game": {
            "description": "Steam 库中已安装的游戏条目。",
            "type": "object",
            "required": ["appid", "name", "basepath", "modpath", "managed"],
            "additionalProperties": false,
            "properties": {
                "appid": {
                    "description": "Steam App ID。",
                    "type": "string"
                },
                "name": {
                    "description": "游戏名称。",
                    "type": "string"
                },
                "localdate": {
                    "description": "最后更新的 Unix 时间戳。",
                    "type": "integer"
                },
                "basepath": {
                    "description": "游戏本体根路径（目录，必须以 / 结尾）。",
                    "type": "string",
                    "pattern": "/$"
                },
                "modpath": {
                    "description": "该游戏的 workshop mod 根路径（目录，必须以 / 结尾）。",
                    "type": "string",
                    "pattern": "/$"
                },
                "mods_found": {
                    "description": "此游戏下发现的 mod contentid 列表。",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "managed": {
                    "description": "是否接受此条目进入流水线。同名 appid 最多一个为 true。",
                    "type": "boolean"
                }
            }
        },
        "Mod": {
            "description": "已发现的 workshop mod 或本地 mod 条目。",
            "type": "object",
            "required": ["mixed_id", "path", "managed"],
            "additionalProperties": false,
            "properties": {
                "mixed_id": {
                    "description": "组合标识，格式 appid:modid。",
                    "type": "string",
                    "pattern": "^\\d+:\\d+$"
                },
                "localdate": {
                    "description": "最后更新的 Unix 时间戳。",
                    "type": "integer"
                },
                "path": {
                    "description": "mod 文件系统根路径（目录，必须以 / 结尾）。",
                    "type": "string",
                    "pattern": "/$"
                },
                "managed": {
                    "description": "是否接受此条目进入流水线。同名 mixed_id 最多一个为 true。",
                    "type": "boolean"
                }
            }
        }
    }
}
