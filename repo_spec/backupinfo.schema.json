{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BackupInfo",
  "description": "Schema for backupinfo.json — the frozen snapshot tree with backup status and hash metadata.",
  "type": "object",
  "required": [
    "schema_namespace",
    "tree_created_time",
    "last_modified_time",
    "schema_version",
    "tree"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_namespace": {
      "type": "string",
      "const": "KMM_BackupInfo",
      "description": "Schema namespace identifier."
    },
    "tree_created_time": {
      "type": "string",
      "format": "date-time",
      "description": "首次建树时刻（prep 写入后不再修改），ISO8601字符串"
    },
    "last_modified_time": {
      "type": "string",
      "format": "date-time",
      "description": "最后一次被本项目工具写入的时刻（每次增量备份更新）"
    },
    "schema_version": {
      "type": "string",
      "const": "knighthana@0.1.0",
      "description": "数据格式必须遵守的schema版本号"
    },
    "tree": {
      "$ref": "#/$defs/DirNode",
      "description": "完整快照树（frozen snapshot），根节点为 base/mod 目录，结构已冻结"
    }
  },
  "$defs": {
    "DirNode": {
      "type": "object",
      "required": ["name", "type", "children"],
      "properties": {
        "name": {"type": "string"},
        "type": {"const": "dir"},
        "children": {
          "type": "array",
          "items": {"oneOf": [{"$ref": "#/$defs/DirNode"}, {"$ref": "#/$defs/FileNode"}]}
        }
      },
      "additionalProperties": false
    },
    "FileNode": {
      "type": "object",
      "required": ["name", "type", "isbackuped", "hashtype", "hashvalue"],
      "properties": {
        "name": {"type": "string"},
        "type": {"const": "file"},
        "isbackuped": {"type": "boolean", "description": "是否已完成备份"},
        "hashtype": {"type": "string", "description": "哈希算法类型"},
        "hashvalue": {"type": "string", "description": "哈希值（hex）"}
      },
      "additionalProperties": false
    }
  }
}
